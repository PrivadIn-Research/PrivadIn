rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------
    // FUNÇÕES DE AUTENTICAÇÃO E SEGURANÇA
    // ----------------------------------------
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isPlayerRoleOnCreate() {
      return request.resource.data.role == "player";
    }

    // Campos que o usuário comum NUNCA pode alterar por conta própria (anti-cheat)
    function userProtectedFields() {
      return [
        "uid", "email", "role", "createdAt",
        "isActive", "deactivatedAt", "deactivatedBy"
      ];
    }

    // Garante que o update não está tentando modificar os campos protegidos acima
    function ownerKeepsProtectedUserFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(userProtectedFields());
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function validPoopcoinHash(hash) {
      return hash is string && hash.matches("^[a-f0-9]{64}$");
    }

    function validPoopcoinEntry(entry) {
      return entry is map
        && entry.keys().hasOnly(["userId", "delta"])
        && entry.userId is string
        && entry.userId.size() > 0
        && entry.userId.size() <= 128
        && entry.delta is int
        && entry.delta != 0
        && entry.delta >= -100000
        && entry.delta <= 100000;
    }

    function validPoopcoinEntries(entries) {
      return entries is list
        && entries.size() >= 1
        && entries.size() <= 2
        && validPoopcoinEntry(entries[0])
        && (entries.size() == 1 || validPoopcoinEntry(entries[1]));
    }

    function validPoopcoinTransaction() {
      return request.resource.data.keys().hasOnly([
          "hash", "previousHash", "sequence", "createdAt", "type", "entries",
          "affectedUserIds", "fromUserId", "toUserId", "amount", "createdBy",
          "createdByRole", "status", "reversesTransactionHash",
          "reversedByTransactionHash", "linkedLogId", "linkedPostId", "reason",
          "nonce"
        ])
        && validPoopcoinHash(request.resource.data.hash)
        && validPoopcoinHash(request.resource.data.previousHash)
        && request.resource.data.sequence is int
        && request.resource.data.sequence > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.type in [
          "mint_log", "legacy_mint", "transfer", "cuiter_spend",
          "admin_adjustment", "reversal"
        ]
        && validPoopcoinEntries(request.resource.data.entries)
        && request.resource.data.affectedUserIds is list
        && request.resource.data.affectedUserIds.size() >= 1
        && request.resource.data.affectedUserIds.size() <= 2
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 100000
        && request.resource.data.createdBy is string
        && request.resource.data.createdByRole in ["player", "admin"]
        && request.resource.data.status == "active"
        && request.resource.data.nonce is string
        && request.resource.data.nonce.size() <= 64
        && (!("reason" in request.resource.data) || request.resource.data.reason == null || (request.resource.data.reason is string && request.resource.data.reason.size() <= 240));
    }

    function validOptionalPoopcoinRuleSettings() {
      return (!("poopcoinsPerLog" in request.resource.data) || (
          request.resource.data.poopcoinsPerLog is int
          && request.resource.data.poopcoinsPerLog >= 1
          && request.resource.data.poopcoinsPerLog <= 100000
        ))
        && (!("cuiterPostCost" in request.resource.data) || (
          request.resource.data.cuiterPostCost is int
          && request.resource.data.cuiterPostCost >= 1
          && request.resource.data.cuiterPostCost <= 100000
        ))
        && (!("poopcoinsPerLogUpdatedAt" in request.resource.data) || request.resource.data.poopcoinsPerLogUpdatedAt is timestamp)
        && (!("poopcoinsPerLogUpdatedBy" in request.resource.data) || request.resource.data.poopcoinsPerLogUpdatedBy is string);
    }

    function hasPoopcoinSupplyFields(data) {
      return "totalSupply" in data
        || "mintedSupply" in data
        || "burnedSupply" in data
        || "circulatingSupply" in data
        || "supplyMigratedAt" in data;
    }

    function validPoopcoinSupplyHead() {
      return !hasPoopcoinSupplyFields(request.resource.data)
        || (
          request.resource.data.totalSupply is int
          && request.resource.data.totalSupply == 1000000
          && request.resource.data.mintedSupply is int
          && request.resource.data.mintedSupply >= 0
          && request.resource.data.mintedSupply <= request.resource.data.totalSupply
          && request.resource.data.burnedSupply is int
          && request.resource.data.burnedSupply >= 0
          && request.resource.data.burnedSupply <= request.resource.data.totalSupply
          && request.resource.data.circulatingSupply is int
          && request.resource.data.circulatingSupply >= 0
          && request.resource.data.circulatingSupply <= request.resource.data.totalSupply
          && request.resource.data.supplyMigratedAt is timestamp
        );
    }

    function userCanCreatePoopcoinTransaction() {
      return signedIn()
        && validPoopcoinTransaction()
        && (request.resource.data.createdBy == request.auth.uid || isAdmin());
    }

    function canUpdatePoopcoinBalance(userId) {
      return signedIn()
        && changedOnly(["poopcoinBalance", "poopcoinMigratedAt"])
        && request.resource.data.poopcoinBalance is number
        && request.resource.data.poopcoinBalance >= -100000
        && request.resource.data.poopcoinBalance <= 1000000
        && (
          isOwner(userId)
          || isAdmin()
          || (
            existsAfter(/databases/$(database)/documents/poopcoin_chain/head)
            && existsAfter(/databases/$(database)/documents/poopcoin_transactions/$(getAfter(/databases/$(database)/documents/poopcoin_chain/head).data.lastHash))
            && getAfter(/databases/$(database)/documents/poopcoin_transactions/$(getAfter(/databases/$(database)/documents/poopcoin_chain/head).data.lastHash)).data.createdBy == request.auth.uid
            && getAfter(/databases/$(database)/documents/poopcoin_transactions/$(getAfter(/databases/$(database)/documents/poopcoin_chain/head).data.lastHash)).data.affectedUserIds.hasAny([userId])
          )
        );
    }


    // ----------------------------------------
    // REGRAS POR COLEÇÃO
    // ----------------------------------------

    // PERFIS DE USUÁRIO
    match /users/{userId} {
      allow read: if signedIn();
      // Permite criar se for o dono
      allow create: if isOwner(userId) && isPlayerRoleOnCreate();
      // Admin edita tudo. Dono edita o que quiser, desde que não trapaceie os pontos/status
      allow update: if (isOwner(userId) && ownerKeepsProtectedUserFields()) || isAdmin() || canUpdatePoopcoinBalance(userId);
      allow delete: if false;
    }

    // LOGS DO JOGO/BANHEIRO
    match /poop_logs/{logId} {
      allow read: if signedIn();
      // O usuário logado só pode criar logs para ele mesmo
      allow create: if (signedIn() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // DADOS PRIVADOS DO USUÁRIO
    match /user_private/{userId} {
      allow read, write: if isOwner(userId);
    }

    // LOGS DE AUDITORIA (ADMIN)
    match /admin_audit_logs/{auditLogId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || (signedIn() && resource.data.action == "reset_weekly");
      allow update, delete: if false;
    }

    // CONFIGURAÇÕES DO APP
    match /app_settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && validOptionalPoopcoinRuleSettings();
      allow delete: if false;
    }

    // REQUISIÇÕES DE CADASTRO
    match /registration_requests/{requestId} {
      allow get, create: if true;
      allow list: if isAdmin();
      allow update: if signedIn() && resource.data.status == "pending" && request.resource.data.status == "used";
      allow delete: if false;
    }

    // TENTATIVAS DE CADASTRO
    match /registration_attempts/{attemptId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // POSTS DO CUITER
    match /cuiter_posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // LEDGER PUBLICO DE POOPCOINS
    match /poopcoin_transactions/{transactionHash} {
      allow read: if signedIn();
      allow create: if transactionHash == request.resource.data.hash && userCanCreatePoopcoinTransaction();
      allow update: if isAdmin()
        && changedOnly(["status", "reversedByTransactionHash"])
        && request.resource.data.status in ["active", "reversed"]
        && request.resource.data.hash == resource.data.hash
        && request.resource.data.previousHash == resource.data.previousHash
        && request.resource.data.sequence == resource.data.sequence;
      allow delete: if false;
    }

    // CABECA DO ENCADEAMENTO POOPCOIN
    match /poopcoin_chain/{chainDoc} {
      allow read: if signedIn();
      allow create, update: if chainDoc == "head"
        && request.resource.data.keys().hasOnly([
          "lastHash", "lastSequence", "updatedAt",
          "totalSupply", "mintedSupply", "burnedSupply",
          "circulatingSupply", "supplyMigratedAt"
        ])
        && validPoopcoinHash(request.resource.data.lastHash)
        && request.resource.data.lastSequence is int
        && request.resource.data.lastSequence >= 0
        && request.resource.data.updatedAt is timestamp
        && validPoopcoinSupplyHead()
        && signedIn();
      allow delete: if false;
    }

  }
}
